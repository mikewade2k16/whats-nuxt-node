generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  AGENT
  VIEWER
}

enum WhatsAppInstanceUserScopePolicy {
  MULTI_INSTANCE
  SINGLE_INSTANCE
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

enum AuditEventType {
  MESSAGE_OUTBOUND_QUEUED
  MESSAGE_OUTBOUND_SENT
  MESSAGE_OUTBOUND_FAILED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_ASSIGNED
}

model Tenant {
  id               String         @id @default(cuid())
  slug             String         @unique
  name             String
  whatsappInstance String?
  evolutionApiKey  String?
  maxChannels      Int            @default(1)
  maxUsers         Int            @default(3)
  retentionDays    Int            @default(15)
  maxUploadMb      Int            @default(500)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  users            User[]
  conversations    Conversation[]
  messages         Message[]
  auditEvents      AuditEvent[]
  savedStickers    SavedSticker[]
  contacts         Contact[]
  hiddenMessages   HiddenMessageForUser[]
  whatsappInstances WhatsAppInstance[]
  whatsappInstanceUserAccesses WhatsAppInstanceUserAccess[]
}

model User {
  id           String         @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  role         UserRole       @default(AGENT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments  Conversation[] @relation("ConversationAssignee")
  outboundMessages Message[]  @relation("MessageSender")
  auditEvents  AuditEvent[]
  savedStickers SavedSticker[] @relation("SavedStickerAuthor")
  hiddenMessages HiddenMessageForUser[]
  whatsappInstanceAccesses WhatsAppInstanceUserAccess[]
  createdWhatsAppInstances WhatsAppInstance[] @relation("WhatsAppInstanceCreator")
  responsibleWhatsAppInstances WhatsAppInstance[] @relation("WhatsAppInstanceResponsible")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model WhatsAppInstance {
  id               String   @id @default(cuid())
  tenantId         String
  instanceName     String
  displayName      String?
  phoneNumber      String?
  evolutionApiKey  String?
  queueLabel       String?
  userScopePolicy  WhatsAppInstanceUserScopePolicy @default(MULTI_INSTANCE)
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdByUserId  String?
  responsibleUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser    User?    @relation("WhatsAppInstanceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  responsibleUser  User?    @relation("WhatsAppInstanceResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  conversations    Conversation[]
  messages         Message[]
  userAccesses     WhatsAppInstanceUserAccess[]

  @@unique([tenantId, instanceName])
  @@index([tenantId, isActive, isDefault])
  @@index([tenantId, responsibleUserId])
}

model WhatsAppInstanceUserAccess {
  id         String           @id @default(cuid())
  tenantId   String
  instanceId String
  userId     String
  createdAt  DateTime         @default(now())
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([instanceId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, instanceId])
}

model SavedSticker {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String?
  name            String
  dataUrl         String   @db.Text
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("SavedStickerAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdByUserId])
}

model Conversation {
  id            String             @id @default(cuid())
  tenantId      String
  instanceId    String?
  instanceScopeKey String          @default("default")
  assignedToId  String?
  contactId     String?
  channel       ChannelType
  externalId    String
  contactName   String?
  contactAvatarUrl String?
  contactPhone  String?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance      WhatsAppInstance?  @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  assignedTo    User?              @relation("ConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  contact       Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages      Message[]
  auditEvents   AuditEvent[]

  @@unique([tenantId, externalId, channel, instanceScopeKey])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([tenantId, instanceScopeKey, lastMessageAt(sort: Desc)])
  @@index([assignedToId])
  @@index([contactId])
  @@index([instanceId])
}

model Message {
  id                String           @id @default(cuid())
  tenantId          String
  conversationId    String
  instanceId        String?
  instanceScopeKey  String           @default("default")
  senderUserId      String?
  direction         MessageDirection
  messageType       MessageType      @default(TEXT)
  senderName        String?
  senderAvatarUrl   String?
  content           String
  mediaUrl          String?
  mediaMimeType     String?
  mediaFileName     String?
  mediaFileSizeBytes Int?
  mediaCaption      String?
  mediaDurationSeconds Int?
  metadataJson      Json?
  externalMessageId String?
  status            MessageStatus    @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  instance          WhatsAppInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  senderUser        User?            @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  auditEvents       AuditEvent[]
  hiddenForUsers    HiddenMessageForUser[]

  @@index([tenantId, createdAt])
  @@index([tenantId, instanceScopeKey, createdAt])
  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@index([instanceId])
}

model AuditEvent {
  id             String         @id @default(cuid())
  tenantId       String
  actorUserId    String?
  conversationId String?
  messageId      String?
  eventType      AuditEventType
  payloadJson    Json?
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser      User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([messageId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}

model Contact {
  id              String         @id @default(cuid())
  tenantId        String
  name            String
  phone           String
  avatarUrl       String?
  source          String         @default("MANUAL")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations   Conversation[]

  @@unique([tenantId, phone])
  @@index([tenantId, name])
  @@index([tenantId, createdAt(sort: Desc)])
}

model HiddenMessageForUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  messageId String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@index([tenantId, messageId])
}
