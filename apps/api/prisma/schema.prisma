generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  AGENT
  VIEWER
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

enum AuditEventType {
  MESSAGE_OUTBOUND_QUEUED
  MESSAGE_OUTBOUND_SENT
  MESSAGE_OUTBOUND_FAILED
  CONVERSATION_STATUS_CHANGED
  CONVERSATION_ASSIGNED
}

model Tenant {
  id               String         @id @default(cuid())
  slug             String         @unique
  name             String
  whatsappInstance String?
  evolutionApiKey  String?
  maxChannels      Int            @default(1)
  maxUsers         Int            @default(2)
  retentionDays    Int            @default(15)
  maxUploadMb      Int            @default(500)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  users            User[]
  conversations    Conversation[]
  messages         Message[]
  auditEvents      AuditEvent[]
  savedStickers    SavedSticker[]
}

model User {
  id           String         @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  role         UserRole       @default(AGENT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments  Conversation[] @relation("ConversationAssignee")
  outboundMessages Message[]  @relation("MessageSender")
  auditEvents  AuditEvent[]
  savedStickers SavedSticker[] @relation("SavedStickerAuthor")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model SavedSticker {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String?
  name            String
  dataUrl         String   @db.Text
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("SavedStickerAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdByUserId])
}

model Conversation {
  id            String             @id @default(cuid())
  tenantId      String
  assignedToId  String?
  channel       ChannelType
  externalId    String
  contactName   String?
  contactAvatarUrl String?
  contactPhone  String?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo    User?              @relation("ConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages      Message[]
  auditEvents   AuditEvent[]

  @@unique([tenantId, externalId, channel])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([assignedToId])
}

model Message {
  id                String           @id @default(cuid())
  tenantId          String
  conversationId    String
  senderUserId      String?
  direction         MessageDirection
  messageType       MessageType      @default(TEXT)
  senderName        String?
  senderAvatarUrl   String?
  content           String
  mediaUrl          String?
  mediaMimeType     String?
  mediaFileName     String?
  mediaFileSizeBytes Int?
  mediaCaption      String?
  mediaDurationSeconds Int?
  metadataJson      Json?
  externalMessageId String?
  status            MessageStatus    @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser        User?            @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  auditEvents       AuditEvent[]

  @@index([tenantId, createdAt])
  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model AuditEvent {
  id             String         @id @default(cuid())
  tenantId       String
  actorUserId    String?
  conversationId String?
  messageId      String?
  eventType      AuditEventType
  payloadJson    Json?
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser      User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([messageId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}
